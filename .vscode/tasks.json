                "${workspaceFolder}",
                "-import",
                "${workspaceFolder}",
                "-cleanBuild",
                "all"
            ],
            "options": {
                "cwd": "C:\\Infineon\\AURIX-Studio-1.10.28"
            },
            "problemMatcher": []
        },
        {
            "label": "Firmware: Flash TC387",
            "type": "shell",
            "command": "C:\\Infineon\\AURIX-Studio-1.10.28\\tools\\AurixFlasherSoftwareTool_v3.0.14\\AURIXFlasher.exe",
            "args": [
                "-hex",
                "${workspaceFolder}/TriCore Debug (TASKING)/stugverter-aurix.hex",
