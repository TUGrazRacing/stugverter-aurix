{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Firmware: Build",
            "type": "shell",
            "command": "C:\\Infineon\\AURIX-Studio-1.10.28\\AURIX-studioc.exe",
            "args": [
                "-nosplash",
                "-consoleLog",
                "-application",
